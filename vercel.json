{
  "buildCommand": "echo 'Skipping build, deploying prebuilt dist folder'",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "lrhkonsult.se" }],
      "destination": "https://www.lrhkonsult.se/:path*",
      "permanent": true
    },
    { "source": "/webbutveckling", "destination": "/tjanster/webbutveckling", "permanent": true },
    { "source": "/seo-optimering", "destination": "/tjanster/seo-optimering", "permanent": true },
    { "source": "/:path+\\/", "destination": "/:path+", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
